# EduCore API — Environment Variables
# Copy to .env and update values for your environment.

DJANGO_SECRET_KEY="django-insecure-^@2&t7y$h#w3^z2*!(local_dev_key_only)m9k%"
DJANGO_SETTINGS_MODULE=educore.settings.dev
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Database (used by base.py — overridden to SQLite in dev.py)
POSTGRES_DB=educore
POSTGRES_USER=educore
POSTGRES_PASSWORD=educore
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Celery / Redis
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Production only
SECURE_SSL_REDIRECT=False
